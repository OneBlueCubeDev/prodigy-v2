  <appSettings>
    
    <add key="Telerik.EnableEmbeddedSkins" value="False" />
    <add key="Telerik.EnableEmbeddedBaseStylesheet" value="True" />
    <!--<add key="Telerik.ScriptManager.TelerikCdn" value="Enabled"/>
    <add key="Telerik.StyleSheetManager.TelerikCdn" value="Enabled"/>-->
    <add key="Telerik.Web.UI.StyleSheetFolders" value="~/App_Themes/Prodigy/; ~/Styles/" />
    <add key="SiteDirectory" value="E:\\DevelopmentCloud\\UACDC\\Programs Online Database\POD\\" />
    <add key="ReportServerUrl" value="http://desktop-600oed3/ReportServer" />
    <add key="ReportServerUserName" value="desktop-600oed3\Spark" />
    <add key="ReportServerPassword" value="" />
    <add key="ReportsBasePath" value="/UACDC/PODReports" />
    <add key="CertificatePath" value="DownLoadedCertificates\" /> 
    <add key="UploadFileFolder" value="DJJNumImportFiles" />
    <add key="aspnet:MaxHttpCollectionKeys" value="2000" />
  <add key="Telerik.Skin" value="Prodigy" />
  <add key="Telerik.ScriptManager.TelerikCdn" value="Disabled" />
  <add key="Telerik.StyleSheetManager.TelerikCdn" value="Disabled" />   
  </appSettings>
  <connectionStrings>
    <add name="PODContextConnection" connectionString="Data Source=DESKTOP-600OED3;Initial Catalog=POD;Integrated Security=SSPI" />
    <add name="PODContext" connectionString="metadata=res://*/Entities.PODContext.csdl|res://*/Entities.PODContext.ssdl|res://*/Entities.PODContext.msl;provider=System.Data.SqlClient;provider connection string=&quot;Data Source=DESKTOP-600OED3;Initial Catalog=POD;Integrated Security=SSPI;multipleactiveresultsets=True;App=EntityFramework&quot;" providerName="System.Data.EntityClient" />
    <!-- TODO: Replace the ****'s with the correct entries --><add name="elmah-sqlserver" connectionString="Data Source=DESKTOP-600OED3;Initial Catalog=POD;Integrated Security=SSPI" providerName="System.Data.SqlClient" />

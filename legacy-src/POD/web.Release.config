<?xml version="1.0" encoding="utf-8"?>

<!-- For more information on using web.config transformation visit http://go.microsoft.com/fwlink/?LinkId=125889 -->

<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
	<!--
		In the example below, the "SetAttributes" transform will change the value of 
		"connectionString" to use "ReleaseSQLServer" only when the "Match" locator 
		finds an attribute "name" that has a value of "MyDB".
	-->  
		<connectionStrings>
			<add name="PODContextConnection" 
				connectionString="Server=tcp:azurepod.database.windows.net,1433;Database=pod;User ID=podadmin@azurepod;Password=P@55W0rd;Encrypt=True;TrustServerCertificate=False;Connection Timeout=90;MultipleActiveResultSets=true;" 
				xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
			<add name="PODContext"
						connectionString="metadata=res://*/Entities.PODContext.csdl|
							res://*/Entities.PODContext.ssdl|	
							res://*/Entities.PODContext.msl;
							provider=System.Data.SqlClient; 
											 provider connection string= 
												'Data Source=tcp:azurepod.database.windows.net,1433; 
												 Initial Catalog=pod; 
												 User ID=podadmin@azurepod;Password=P@55W0rd; 
												 MultipleActiveResultSets=true'"
						xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
			<add name="elmah-sqlserver"
				connectionString="Server=tcp:azurepod.database.windows.net,1433;Database=POD;User ID=podadmin@azurepod;Password=P@55W0rd;Encrypt=True;TrustServerCertificate=False;Connection Timeout=90;"
				xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
		</connectionStrings>
	
	<appSettings>
		<add key="ReportServerUrl" value="http://podreports6.cloudapp.net/reportserver" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
		<add key="ReportServerUserName" value="podreports" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
		<add key="ReportServerPassword" value="C*@tv134" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
		<add key="ReportsBasePath" value="/PODReports" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
	</appSettings>
	<system.web>
		<compilation xdt:Transform="RemoveAttributes(debug)" />
		<!--
			In the example below, the "Replace" transform will replace the entire 
			<customErrors> section of your web.config file.
			Note that because there is only one customErrors section under the 
			<system.web> node, there is no need to use the "xdt:Locator" attribute.
			
			<customErrors defaultRedirect="GenericError.htm"
				mode="RemoteOnly" xdt:Transform="Replace">
				<error statusCode="500" redirect="InternalError.htm"/>
			</customErrors>
		-->
	</system.web>
</configuration>
                var finalName = "{0} {1} [{2}] {3}-{4} {5} {6}".f(firstInitial, lastName, enteredClassName, startdt, enddt, selectedAgeGroup, selectedLocation);

                
                
                //alert(finalName);
                $('#<%=lblCalcName.ClientID%>').empty();

                

                //end experiement
               

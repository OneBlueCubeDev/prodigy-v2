                    POD.Logic.PersonRelatedLogic.AddUpdateClassAttendance(0, personid, ClassID, leftEarly, isTardy, this.TextBoxNotes.Text.Trim(), isAlternateActivity);
                    this.RadGriAttendancesClass.Rebind();

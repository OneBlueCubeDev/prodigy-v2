                    int.TryParse(ViewState["CourseID"].ToString(), out courseId);
                }
                return courseId;
            }
            set
            {
                ViewState["CourseID"] = value;
            }
        }
        public int LpsId
        {
            get
            {
                if (ViewState["lpsId"] != null)
                {
                    int.TryParse(ViewState["lpsId"].ToString(), out lpsId);
                }
                return lpsId;
            }

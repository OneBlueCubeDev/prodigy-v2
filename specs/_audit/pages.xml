                        ListItem referredBy = this.CheckBoxListRiskAssessmentReferral.Items.FindByValue(str);
                        if (referredBy != null)
                        {
                            referredBy.Selected = true;
                            if (referredBy.Value == "Other")
                            {
                                this.RiskAssessmentReferralOtherTextBox.Text = currentRA.RefByOther;
                            }

        public static int DetermineLegalStatus(string status)
        {
            int result = 0;
            if (status.ToLower() != null)
            {
                switch (status.ToLower().Trim())
                {
                    case "mother":
                        result = 1;
                        break;
                    case "father":
                        result = 2;
                        break;
                    case "legal guardian":
                        result = 3;
                        break;
                    case "other":
                        result = 4;
                        break;
                    case "friend":
                        result = 5;
                        break;
                    case "sibling":
                        result = 6;
                        break;
                    case "relative":
                        result = 7;
                        break;

                    default:
                        break;
                }
            }

            return result;
        }

        public static int DetermineYouthParentalStatus(string status)
        {
            int result = 0;
            if (status != null)
            {
                switch (status.ToLower().Trim())
                {
                    case "none":

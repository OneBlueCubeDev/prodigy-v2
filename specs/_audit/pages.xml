                $(".mytextbox").each(function () {
                    //Get Value
                    var textboxValue = $(this).val();
                    //Create span with value
                    $(this).after("<span class='PrintTextValue'>" + textboxValue + "</span>");
                });

                $(".mytextbox").blur(function () {
                    PrintTextFieldSwap();

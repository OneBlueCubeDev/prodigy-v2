using System;
using System.Collections.Generic;
using System.Linq;
using System.Web;
using System.Web.UI;
using System.Web.UI.WebControls;
using POD.Data.Entities;
using Telerik.Web.UI;
using POD.Logic;
using System.Globalization;

namespace POD.Pages
{
    public static class DateTimeExtension
    {
        public static DateTime GetPreviousWeekDay(this DateTime currentDate, DayOfWeek dow, bool blndblweek = false)
        {
            double counter;
            int currentDay = (int)currentDate.DayOfWeek, gotoDay = (int)dow;
            counter = (blndblweek == false ? -7 : -14 );
            return currentDate.AddDays(counter).AddDays(gotoDay - currentDay);
        }

        public static DateTime GetNextWeekDay(this DateTime currentDate, DayOfWeek dow)
        {
            int currentDay = (int)currentDate.DayOfWeek, gotoDay = (int)dow;
            return currentDate.AddDays(7).AddDays(gotoDay - currentDay);
        }

       
    }

    public partial class AttendancePage : System.Web.UI.Page
    {
        private int classID = 0;
        private int eventid = 0;
        string typeOfAttendance = string.Empty;
        private int EventID
        {
            get
            {
                if (ViewState["EventID"] != null)
                {
                    int.TryParse(ViewState["EventID"].ToString(), out eventid);
                }
                return eventid;
            }
            set
            {
                ViewState["EventID"] = value;
            }
        }

        private int ClassID
        {
            get
            {
                if (ViewState["ClassID"] != null)
                {
                    int.TryParse(ViewState["ClassID"].ToString(), out classID);
                }
                return classID;
            }
            set
            {
                ViewState["ClassID"] = value;
            }
        }

        protected DateTime DetermineLockDate()
        {
            

            
            var dateValue = DateTime.Parse(DateTime.Now.ToString(), CultureInfo.InvariantCulture);
            DateTime result = dateValue;

            var currentTime = dateValue.Hour; //check to see time great or equal to 16

            DateTime currentDate = DateTime.Now;
            var lastfriday = currentDate.GetPreviousWeekDay(DayOfWeek.Friday);
            var dbllastfriday = currentDate.GetPreviousWeekDay(DayOfWeek.Friday, true);
            var uup = currentDate.GetNextWeekDay(DayOfWeek.Wednesday);

            Class currentCass = POD.Logic.ProgramCourseClassLogic.GetClassByID(ClassID);
            if (currentCass != null)
            {
                          
                if (dateValue.DayOfWeek == DayOfWeek.Monday)
                {
                    if (currentCass.DateStart.Value.Date >= dbllastfriday.Date)
                    {
                        result = dbllastfriday.Date;
                    }
                }
                else if (dateValue.DayOfWeek == DayOfWeek.Tuesday)
                {
                    if (currentCass.DateStart.Value.Date >= dbllastfriday.Date)
                    {
                        result = dbllastfriday.Date;
                    }
                }
                else if (dateValue.DayOfWeek == DayOfWeek.Wednesday)
                {
                    
                    if (currentTime >= 16)
                    {
                        
                        if (currentCass.DateStart.Value.Date > lastfriday.Date)
                        {
                            result = dbllastfriday.Date;
                        }
                        else
                        {
                            result = lastfriday.Date;
                        }
                    }
                    else 
                    {
                        if (currentCass.DateStart.Value.Date <= dbllastfriday.Date)
                        {
                            result = dbllastfriday.Date;
                        }
                        else
                        {
                            if (currentCass.DateStart.Value.Date >= dbllastfriday.Date)
                            {
                                result = dbllastfriday.Date;
                            }
                        }
                    }

                }
                else if (dateValue.DayOfWeek == DayOfWeek.Thursday)
                {
                    if (currentCass.DateStart.Value.Date > lastfriday.Date)
                    {
                        result = dbllastfriday.Date;
                    }
                    else
                    {
                        result = lastfriday.Date;
                    }
                }
                else if (dateValue.DayOfWeek == DayOfWeek.Friday)
                {
                    if (currentCass.DateStart.Value.Date > lastfriday.Date)
                    {
                        result = dbllastfriday.Date;
                    }
                    else
                    {
                        result = lastfriday.Date;
                    }
                }
                else if (dateValue.DayOfWeek == DayOfWeek.Saturday)
                {
                    if (currentCass.DateStart.Value.Date > lastfriday.Date)
                    {
                        result = dbllastfriday.Date;
                    }
                    else
                    {
                        result = lastfriday.Date;
                    }
                }
                else if (dateValue.DayOfWeek == DayOfWeek.Sunday)
                {
                    if (currentCass.DateStart.Value.Date > lastfriday.Date)
                    {
                        result = dbllastfriday.Date;
                    }
                    else
                    {
                        result = lastfriday.Date;
                    }
                }
            }

            return result;
        }

        protected void Page_Load(object sender, EventArgs e)
        {
            if (!IsPostBack)
            {

                if (!string.IsNullOrEmpty(Request.QueryString["cid"]))
                {
                    int.TryParse(Request.QueryString["cid"].ToString(), out classID);
                    ClassID = classID;
                }
                var lockeddt = DetermineLockDate();

                var dateValue = DateTime.Parse(DateTime.Now.ToString(), CultureInfo.InvariantCulture);
                var dayofWeek = (int)dateValue.DayOfWeek; //check to see if day of week = 3
                var currentTime = dateValue.Hour; //check to see time great or equal to 16

                if (!string.IsNullOrEmpty(Request.QueryString["type"]))
                {
                    typeOfAttendance = Request.QueryString["type"].ToString();

                }



                    if (typeOfAttendance == "Class")
                    {
                        this.PanelClassRecord.Visible = true;
                        this.PanelEventRecord.Visible = false;
                        if (!string.IsNullOrEmpty(Request.QueryString["cid"]))
                        {
                            int.TryParse(Request.QueryString["cid"].ToString(), out classID);
                            ClassID = classID;
                            Class currentCass = POD.Logic.ProgramCourseClassLogic.GetClassByID(ClassID);
                            if (currentCass != null)
                            {
                                if (currentCass.Site.MandatoryAttendanceLock == true)
                                {
                                    if (currentCass.DateStart.HasValue &&
                                        currentCass.DateStart.Value.Date <= lockeddt)
                                    {
                                        
                                        this.PanelClassNewAttendance.Visible = false;
                                        this.PanelClassAttendanceLocked.Visible = true;
                                    }
                                }
                            }
                        }
                    }
                    else if (typeOfAttendance == "Event")
                    {
                        this.PanelClassRecord.Visible = false;
                        this.PanelEventRecord.Visible = true;
                        if (!string.IsNullOrEmpty(Request.QueryString["cid"]))
                        {
                            int.TryParse(Request.QueryString["cid"].ToString(), out eventid);
                            EventID = eventid;
                            Event currentEvent = POD.Logic.ProgramCourseClassLogic.GetEvent(EventID);
                            if (currentEvent != null)
                            {



                                if (currentEvent.Site.MandatoryAttendanceLock.HasValue)
                                {
                                    if (currentEvent.DateStart.HasValue &&
                                        currentEvent.DateStart.Value.Date <= lockeddt)
                                    {
                                        this.PanelNewEventAttendance.Visible = false;
                                        this.PanelEventAttendanceLocked.Visible = true;
                                    }
                                }
                            }
                        }
                    }
                //only admin and central admins can delete
                if (!Security.UserInRole("Administrators") &&
                    !Security.UserInRole("CentralTeamUsers") && !Security.UserInRole("SiteTeamUsers"))
                {
                    this.RadMenuOptions.Visible = false;
                    this.RadContextMenuEA.Visible = false;
                }
                LoadDropdowns();
            }
        }



